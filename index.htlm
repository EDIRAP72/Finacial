<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <title>Money Flow & Demand/Offer</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body {
      margin: 0;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #05070a;
      color: #f5f5f5;
    }
    header {
      padding: 16px 20px;
      border-bottom: 1px solid #222;
      background: #05070a;
    }
    header h1 {
      margin: 0;
      font-size: 20px;
    }
    header p {
      margin: 4px 0 0;
      font-size: 12px;
      color: #aaa;
    }
    .container {
      padding: 16px;
    }
    .heatmap-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 10px;
    }
    .tile {
      padding: 10px;
      border-radius: 8px;
      cursor: pointer;
      border: 1px solid #222;
      transition: transform 0.1s ease, box-shadow 0.1s ease, border-color 0.1s ease;
    }
    .tile:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 10px rgba(0,0,0,0.6);
      border-color: #888;
    }
    .ticker {
      font-weight: 600;
      font-size: 16px;
      margin-bottom: 4px;
    }
    .asset-type {
      font-size: 11px;
      color: #ccc;
      margin-bottom: 6px;
    }
    .metric {
      font-size: 11px;
      color: #ddd;
    }
    .metric span {
      color: #aaa;
    }
    .badge {
      display: inline-block;
      padding: 2px 6px;
      border-radius: 999px;
      font-size: 10px;
      margin-top: 4px;
      background: rgba(0,0,0,0.4);
      border: 1px solid rgba(255,255,255,0.1);
    }
    .view-title {
      font-size: 18px;
      margin-bottom: 8px;
    }
    .back-btn {
      display: inline-block;
      margin-bottom: 12px;
      font-size: 13px;
      color: #9cf;
      cursor: pointer;
    }
    .back-btn:hover {
      text-decoration: underline;
    }
    .detail-layout {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }
    @media (min-width: 800px) {
      .detail-layout {
        flex-direction: row;
      }
    }
    .detail-left, .detail-right {
      flex: 1;
      min-width: 0;
    }
    canvas {
      width: 100%;
      max-width: 100%;
      background: #0b0f16;
      border-radius: 8px;
      border: 1px solid #222;
    }
    .section-title {
      font-size: 14px;
      margin: 8px 0;
      color: #ddd;
    }
    .stat-line {
      font-size: 12px;
      margin: 2px 0;
      color: #ccc;
    }
    .entries-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 12px;
      margin-top: 6px;
    }
    .entries-table th,
    .entries-table td {
      padding: 4px 6px;
      border-bottom: 1px solid #222;
      text-align: left;
    }
    .entries-table th {
      color: #aaa;
      font-weight: 500;
    }
    .success-high {
      color: #4fd18b;
    }
    .success-mid {
      color: #f0c14b;
    }
    .success-low {
      color: #f26c6c;
    }
  </style>
</head>
<body>
  <header>
    <h1>Top 20 – Money Flow & Demand/Offer</h1>
    <p>20 titoli (ETF, azioni, commodity, obbligazioni) basati sul flusso dei soldi domanda/offerta.</p>
  </header>

  <div class="container">
    <!-- VIEW 1: HEATMAP -->
    <div id="heatmap-view">
      <div class="heatmap-grid" id="heatmap-grid"></div>
    </div>

    <!-- VIEW 2: DETTAGLIO TITOLO -->
    <div id="detail-view" style="display:none;">
      <div class="back-btn" id="back-btn">← Torna alla heatmap</div>
      <div class="view-title" id="detail-title"></div>
      <div class="detail-layout">
        <div class="detail-left">
          <div class="section-title">Grafico storico (3 anni) + proiezione 1 mese</div>
          <canvas id="chart-canvas" width="600" height="320"></canvas>
        </div>
        <div class="detail-right">
          <div class="section-title">Dati sintetici usati nel calcolo</div>
          <div id="detail-stats"></div>

          <div class="section-title">Migliori 5 prezzi di entrata (calcolati)</div>
          <table class="entries-table" id="entries-table">
            <thead>
              <tr>
                <th>#</th>
                <th>Prezzo entrata</th>
                <th>Probabilità di successo</th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <script>
    // =========================
    // DATI DI BASE: 20 TITOLI
    // =========================
    const instruments = [
      { ticker: "AAPL", name: "Apple Inc.", type: "Azione", basePrice: 190, moneyFlow: 0.65, liquidity: 0.95 },
      { ticker: "MSFT", name: "Microsoft Corp.", type: "Azione", basePrice: 380, moneyFlow: 0.58, liquidity: 0.93 },
      { ticker: "AMZN", name: "Amazon.com Inc.", type: "Azione", basePrice: 210, moneyFlow: 0.52, liquidity: 0.9 },
      { ticker: "GOOG", name: "Alphabet Inc.", type: "Azione", basePrice: 280, moneyFlow: 0.49, liquidity: 0.9 },
      { ticker: "META", name: "Meta Platforms", type: "Azione", basePrice: 290, moneyFlow: 0.55, liquidity: 0.88 },
      { ticker: "TSLA", name: "Tesla Inc.", type: "Azione", basePrice: 360, moneyFlow: 0.4, liquidity: 0.85 },
      { ticker: "NVDA", name: "NVIDIA Corp.", type: "Azione", basePrice: 500, moneyFlow: 0.7, liquidity: 0.92 },
      { ticker: "INTC", name: "Intel Corp.", type: "Azione", basePrice: 44, moneyFlow: 0.35, liquidity: 0.8 },
      { ticker: "XOM", name: "Exxon Mobil", type: "Commodity/Oil", basePrice: 160, moneyFlow: 0.6, liquidity: 0.87 },
      { ticker: "CVX", name: "Chevron Corp.", type: "Commodity/Oil", basePrice: 200, moneyFlow: 0.57, liquidity: 0.84 },
      { ticker: "GLD", name: "Gold ETF", type: "ETF Commodity", basePrice: 190, moneyFlow: 0.5, liquidity: 0.9 },
      { ticker: "TLT", name: "20+ Year Treasury", type: "ETF Obbligazioni", basePrice: 95, moneyFlow: 0.42, liquidity: 0.86 },
      { ticker: "HYG", name: "High Yield Corp Bond", type: "ETF Obbligazioni", basePrice: 78, moneyFlow: 0.38, liquidity: 0.82 },
      { ticker: "SPY", name: "S&P 500 ETF", type: "ETF Azionario", basePrice: 520, moneyFlow: 0.62, liquidity: 0.98 },
      { ticker: "QQQ", name: "Nasdaq 100 ETF", type: "ETF Azionario", basePrice: 440, moneyFlow: 0.59, liquidity: 0.96 },
      { ticker: "LQD", name: "Investment Grade Corp Bond", type: "ETF Obbligazioni", basePrice: 110, moneyFlow: 0.41, liquidity: 0.88 },
      { ticker: "USO", name: "US Oil Fund", type: "ETF Commodity", basePrice: 75, moneyFlow: 0.48, liquidity: 0.83 },
      { ticker: "SLV", name: "Silver Trust", type: "ETF Commodity", basePrice: 25, moneyFlow: 0.44, liquidity: 0.8 },
      { ticker: "BND", name: "Total Bond Market", type: "ETF Obbligazioni", basePrice: 80, moneyFlow: 0.39, liquidity: 0.9 },
      { ticker: "EEM", name: "Emerging Markets ETF", type: "ETF Azionario", basePrice: 42, moneyFlow: 0.36, liquidity: 0.78 }
    ];

    // =========================
    // HEATMAP
    // =========================
    const heatmapGrid = document.getElementById("heatmap-grid");
    const heatmapView = document.getElementById("heatmap-view");
    const detailView = document.getElementById("detail-view");
    const detailTitle = document.getElementById("detail-title");
    const detailStats = document.getElementById("detail-stats");
    const entriesTableBody = document.querySelector("#entries-table tbody");
    const backBtn = document.getElementById("back-btn");
    const chartCanvas = document.getElementById("chart-canvas");
    const ctx = chartCanvas.getContext("2d");

    function moneyFlowToColor(mf) {
      // mf 0..1 -> da rosso (scarico) a verde (carico)
      const r = Math.round(255 * (1 - mf));
      const g = Math.round(255 * mf);
      const b = 60;
      return `rgb(${r},${g},${b})`;
    }

    function renderHeatmap() {
      heatmapGrid.innerHTML = "";
      instruments.forEach((inst, idx) => {
        const tile = document.createElement("div");
        tile.className = "tile";
        tile.style.background = `linear-gradient(135deg, ${moneyFlowToColor(inst.moneyFlow)} 0%, #05070a 60%)`;

        const ticker = document.createElement("div");
        ticker.className = "ticker";
        ticker.textContent = inst.ticker;

        const type = document.createElement("div");
        type.className = "asset-type";
        type.textContent = inst.type;

        const metric1 = document.createElement("div");
        metric1.className = "metric";
        metric1.innerHTML = `<span>Prezzo:</span> ${inst.basePrice.toFixed(2)}`;

        const metric2 = document.createElement("div");
        metric2.className = "metric";
        const score = (inst.moneyFlow * inst.liquidity * 1_000_000).toFixed(0);
        metric2.innerHTML = `<span>Score flusso:</span> ${score}`;

        const metric3 = document.createElement("div");
        metric3.className = "metric";
        const volRel = (0.8 + inst.moneyFlow * 1.4).toFixed(2);
        metric3.innerHTML = `<span>Vol rel:</span> ${volRel}`;

        const badge = document.createElement("div");
        badge.className = "badge";
        badge.textContent = "Domanda/Offerta attiva";

        tile.appendChild(ticker);
        tile.appendChild(type);
        tile.appendChild(metric1);
        tile.appendChild(metric2);
        tile.appendChild(metric3);
        tile.appendChild(badge);

        tile.addEventListener("click", () => openDetail(inst, idx));
        heatmapGrid.appendChild(tile);
      });
    }

    // =========================
    // DETTAGLIO: CALCOLO + GRAFICO
    // =========================

    function generateHistoricalSeries(basePrice, moneyFlow, liquidity) {
      // 3 anni ~ 36 mesi (semplificato)
      const points = 36;
      const data = [];
      let price = basePrice * (0.7 + Math.random() * 0.2); // parte un po' più in basso
      const trend = (moneyFlow - 0.5) * 0.08 * basePrice; // trend medio annuo
      const monthlyTrend = trend / 12;

      for (let i = points - 1; i >= 0; i--) {
        const noise = (Math.random() - 0.5) * basePrice * 0.03 * (1 + (1 - liquidity));
        price = Math.max(0.1, price + monthlyTrend + noise);
        data.unshift(price);
      }
      return data;
    }

    function projectFutureSeries(lastPrice, moneyFlow, liquidity) {
      // Proiezione 1 mese ~ 20 punti (giorni)
      const points = 20;
      const data = [];
      let price = lastPrice;
      const dailyTrend = (moneyFlow - 0.5) * 0.02 * lastPrice; // trend giornaliero sintetico

      for (let i = 0; i < points; i++) {
        const noise = (Math.random() - 0.5) * lastPrice * 0.01 * (1 + (1 - liquidity));
        price = Math.max(0.1, price + dailyTrend + noise);
        data.push(price);
      }
      return data;
    }

    function drawChart(historical, projected) {
      const w = chartCanvas.width;
      const h = chartCanvas.height;
      ctx.clearRect(0, 0, w, h);

      const all = historical.concat(projected);
      const minP = Math.min(...all);
      const maxP = Math.max(...all);
      const pad = 20;

      function xScale(i, total) {
        return pad + (w - 2 * pad) * (i / (total - 1));
      }
      function yScale(p) {
        return h - pad - (h - 2 * pad) * ((p - minP) / (maxP - minP || 1));
      }

      // sfondo
      ctx.fillStyle = "#05070a";
      ctx.fillRect(0, 0, w, h);

      // griglia semplice
      ctx.strokeStyle = "#111";
      ctx.lineWidth = 1;
      for (let i = 0; i <= 4; i++) {
        const y = pad + (h - 2 * pad) * (i / 4);
        ctx.beginPath();
        ctx.moveTo(pad, y);
        ctx.lineTo(w - pad, y);
        ctx.stroke();
      }

      // storico (linea piena)
      ctx.strokeStyle = "#4fd18b";
      ctx.lineWidth = 2;
      ctx.beginPath();
      historical.forEach((p, i) => {
        const x = xScale(i, historical.length + projected.length);
        const y = yScale(p);
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      });
      ctx.stroke();

      // proiezione (linea tratteggiata)
      ctx.strokeStyle = "#f0c14b";
      ctx.setLineDash([6, 4]);
      ctx.beginPath();
      projected.forEach((p, i) => {
        const x = xScale(historical.length + i, historical.length + projected.length);
        const y = yScale(p);
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      });
      ctx.stroke();
      ctx.setLineDash([]);

      // legenda
      ctx.font = "11px system-ui";
      ctx.fillStyle = "#ccc";
      ctx.fillText("Storico (3 anni)", pad + 4, pad + 12);
      ctx.fillStyle = "#f0c14b";
      ctx.fillText("Proiezione (1 mese)", pad + 4, pad + 26);
    }

    function computeEntryPrices(lastPrice, moneyFlow, liquidity) {
      // 5 prezzi di entrata attorno al prezzo attuale
      const entries = [];
      const baseVol = 0.04 + (1 - liquidity) * 0.04; // ampiezza
      for (let i = -2; i <= 2; i++) {
        const offset = i * baseVol * lastPrice;
        const price = lastPrice + offset;
        // probabilità sintetica: più alta se moneyFlow alto e prezzo leggermente scontato
        const discountFactor = 1 - Math.abs(i) * 0.08;
        let success = 40 + moneyFlow * 50 + discountFactor * 10;
        success = Math.max(10, Math.min(95, success));
        entries.push({
          price: price,
          success: success
        });
      }
      // ordina per successo decrescente
      entries.sort((a, b) => b.success - a.success);
      return entries;
    }

    function successClass(p) {
      if (p >= 70) return "success-high";
      if (p >= 50) return "success-mid";
      return "success-low";
    }

    function openDetail(inst, idx) {
      heatmapView.style.display = "none";
      detailView.style.display = "block";

      detailTitle.textContent = `${inst.ticker} – ${inst.name}`;

      // "Calcolo matematico complesso" sintetico basato su:
      // volumi (derivati da liquidity), domanda/offerta (moneyFlow), 3 anni di storico
      const historical = generateHistoricalSeries(inst.basePrice, inst.moneyFlow, inst.liquidity);
      const projected = projectFutureSeries(historical[historical.length - 1], inst.moneyFlow, inst.liquidity);

      drawChart(historical, projected);

      const avgPrice = historical.reduce((a, b) => a + b, 0) / historical.length;
      const volApprox = historical.reduce((acc, p) => acc + Math.abs(p - avgPrice), 0) / historical.length;
      const lastPrice = historical[historical.length - 1];

      detailStats.innerHTML = `
        <div class="stat-line">Tipo strumento: <strong>${inst.type}</strong></div>
        <div class="stat-line">Prezzo attuale sintetico: <strong>${lastPrice.toFixed(2)}</strong></div>
        <div class="stat-line">Flusso domanda/offerta (0–1): <strong>${inst.moneyFlow.toFixed(2)}</strong></div>
        <div class="stat-line">Liquidità (0–1): <strong>${inst.liquidity.toFixed(2)}</strong></div>
        <div class="stat-line">Storico utilizzato: <strong>3 anni (36 punti mensili sintetici)</strong></div>
        <div class="stat-line">Volatilità media sintetica: <strong>${volApprox.toFixed(2)}</strong></div>
      `;

      const entries = computeEntryPrices(lastPrice, inst.moneyFlow, inst.liquidity);
      entriesTableBody.innerHTML = "";
      entries.forEach((e, i) => {
        const tr = document.createElement("tr");
        const tdIdx = document.createElement("td");
        const tdPrice = document.createElement("td");
        const tdSucc = document.createElement("td");

        tdIdx.textContent = i + 1;
        tdPrice.textContent = e.price.toFixed(2);
        tdSucc.textContent = e.success.toFixed(1) + " %";
        tdSucc.className = successClass(e.success);

        tr.appendChild(tdIdx);
        tr.appendChild(tdPrice);
        tr.appendChild(tdSucc);
        entriesTableBody.appendChild(tr);
      });
    }

    backBtn.addEventListener("click", () => {
      detailView.style.display = "none";
      heatmapView.style.display = "block";
    });

    // Init
    renderHeatmap();
  </script>
</body>
</html>
